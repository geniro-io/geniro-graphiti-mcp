# Geniro Graphiti MCP — environment configuration.
# Copy to `.env` and fill in. NEVER commit a real `.env`.

# ── Neo4j (graph store) ──────────────────────────────────────────────
# Matches the bundled docker-compose.yml defaults.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=demodemo
NEO4J_DATABASE=neo4j

# ── Main LLM (entity / relationship extraction) ──────────────────────
# LLM_PROVIDER ∈ openai | anthropic | openai_generic
#   openai          → OpenAI native (default model gpt-5.5)
#   anthropic       → native Claude (requires the `anthropic` extra)
#   openai_generic  → any OpenAI-compatible endpoint via LLM_BASE_URL
#                     (LiteLLM proxy, Ollama, vLLM, OpenRouter, …)
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.5
# Only used for openai_generic. e.g. http://localhost:11434/v1 (Ollama)
# or http://localhost:4000/v1 (LiteLLM).
LLM_BASE_URL=
OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Embedder (vector embeddings — REQUIRED, independent of the LLM) ───
# EMBEDDER_PROVIDER ∈ openai | ollama | voyage | openai_generic
# IMPORTANT: the embedder MUST be an EMBEDDING model, not a chat model.
#   qwen3-embedding:8b is correct;  qwen3:8b is a chat model and breaks search.
# EMBEDDER_DIM MUST match the model's output dimension or search breaks.
EMBEDDER_PROVIDER=ollama
EMBEDDER_MODEL=qwen3-embedding:8b
EMBEDDER_DIM=4096
EMBEDDER_BASE_URL=http://localhost:11434/v1
# For EMBEDDER_PROVIDER=openai, omit EMBEDDER_BASE_URL and set:
#   EMBEDDER_MODEL=text-embedding-3-small
#   EMBEDDER_DIM=1536
# EMBEDDER_API_KEY is reused from OPENAI_API_KEY unless set explicitly.
# EMBEDDER_API_KEY=

# ── Workspace (memory namespace) ─────────────────────────────────────
# Partitions memory so one MCP can serve many projects. Set this per
# registration (e.g. one project = one workspace) for isolated memory.
# Not a security boundary — just a partition key.
GRAPHITI_WORKSPACE=main
# Backward-compatible alias (graphiti-core's native term). GRAPHITI_WORKSPACE
# wins when both are set.
# GRAPHITI_GROUP_ID=main
# Concurrency cap for graphiti-core's internal coroutines.
SEMAPHORE_LIMIT=10

# graphiti-core's anonymous usage telemetry is disabled by default for this
# local tool. Set to true to re-enable it.
# GRAPHITI_TELEMETRY_ENABLED=false
